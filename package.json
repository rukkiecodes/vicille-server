{
  "name": "vicelle-backend",
  "version": "1.0.0",
  "description": "Subscription-based fashion & tailoring platform backend built with Node.js, Supabase/PostgreSQL, GraphQL, and Socket.io",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'No build step required'",
    "migrate": "node migrations/seed.js",
    "migrate:all": "node migrations/seed.js",
    "migrate:012": "node migrations/run-012.js",
    "migrate:013": "node migrations/run-013.js",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "vicelle",
    "tailoring",
    "subscription",
    "fashion",
    "supabase",
    "postgresql",
    "graphql",
    "socketio"
  ],
  "author": "Vicelle Team",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "@graphql-tools/merge": "^9.0.1",
    "@graphql-tools/schema": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "graphql-upload-minimal": "^1.5.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "pg": "^8.13.3",
    "redis": "^5.10.0",
    "socket.io": "^4.6.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.6",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0 <21.0.0",
    "npm": ">=9.0.0"
  }
}
