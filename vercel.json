{
  "version": 2,
  "buildCommand": "npm run build 2>/dev/null || echo 'No build step'",
  "devCommand": "npm run dev",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/server.js": {
      "runtime": "nodejs@20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "public": false,
  "headers": [
    {
      "source": "/graphql",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
