{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/stitchd-payouts",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/cron/stitchd-billing",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/cron/stitchd-account-purge",
      "schedule": "30 8 * * *"
    }
  ]
}
